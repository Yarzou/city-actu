# Template de configuration Liquibase (versionné — sans données sensibles)
# Copier ce fichier : cp liquibase/liquibase.properties.example liquibase/liquibase.properties
# Puis renseigner les valeurs (Supabase Dashboard > Project Settings > Database)

url=jdbc:postgresql://db.XXXX.supabase.co:5432/postgres
username=postgres
password=YOUR_DB_PASSWORD

driver=org.postgresql.Driver
changeLogFile=liquibase/changelog/db.changelog-master.xml
outputDefaultSchema=false
